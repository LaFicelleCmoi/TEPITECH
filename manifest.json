{
  "manifest_version": 3,
  "name": "Traducteur Universel",
  "version": "1.0.0",
  "description": "Traducteur polyvalent : sélection, QCM et sous-titres live. Style Liquid Glass.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting",
    "tts",
    "tabCapture"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Traducteur Universel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
